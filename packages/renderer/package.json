{
  "name": "framedeck-renderer",
  "version": "0.1.6",
  "description": "Node and browser renderer for FrameDeck screenshot documents.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/DjDeveloperr/FrameDeck.git",
    "directory": "packages/renderer"
  },
  "bugs": {
    "url": "https://github.com/DjDeveloperr/FrameDeck/issues"
  },
  "homepage": "https://github.com/DjDeveloperr/FrameDeck#readme",
  "keywords": [
    "app-store",
    "screenshots",
    "renderer",
    "device-frames"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "framedeck-core": "^0.1.6",
    "yoga-layout": "^3.2.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.3"
  }
}
