{
  "name": "@framedeck/cli",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "framedeck": "./bin/framedeck.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "bin", "assets"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepack": "node ../../scripts/prepare-cli-package.mjs",
    "postpack": "node ../../scripts/clean-cli-package.mjs",
    "start": "node bin/framedeck.js"
  },
  "dependencies": {
    "@framedeck/core": "*",
    "@framedeck/renderer": "*",
    "chokidar": "^4.0.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.0"
  }
}
