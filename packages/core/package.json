{
  "name": "framedeck-core",
  "version": "0.1.1",
  "description": "Core parser, project, and device metadata utilities for FrameDeck.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/DjDeveloperr/FrameDeck.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/DjDeveloperr/FrameDeck/issues"
  },
  "homepage": "https://github.com/DjDeveloperr/FrameDeck#readme",
  "keywords": [
    "app-store",
    "screenshots",
    "parser",
    "device-frames"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fs": {
      "types": "./dist/fs.d.ts",
      "import": "./dist/fs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "htmlparser2": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.3"
  }
}
